rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "dkumar.iit.b.2026@gmail.com";
    }

    match /prompts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
